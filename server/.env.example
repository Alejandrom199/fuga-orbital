# Postgres de Supabase — conexión directa (5432) o session pooler.
# El servidor es persistente (Railway), no serverless, así que cualquiera de las dos sirve.
DATABASE_URL=postgresql://usuario:password@host:5432/postgres

# Secreto para firmar el JWT que viaja en la cookie httpOnly (usa una cadena larga y aleatoria).
JWT_SECRET=cambia-este-valor-por-un-secreto-largo-y-aleatorio

# Secreto para firmar la cookie (@fastify/cookie). Puede ser distinto de JWT_SECRET.
COOKIE_SECRET=cambia-este-valor-tambien

PORT=3001

# Origen del cliente (Vite en dev, Netlify en producción) para configurar CORS.
CLIENT_ORIGIN=http://localhost:5173

NODE_ENV=development
