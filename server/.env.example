# Postgres de Supabase — usar el "Session pooler" (Settings → Database → Connection
# string), NO la conexión directa: esta última resuelve a IPv6 y Railway no tiene
# salida IPv6, así que la conexión directa falla con ENETUNREACH en producción.
DATABASE_URL=postgresql://postgres.proyecto:password@aws-region.pooler.supabase.com:5432/postgres

# Secreto para firmar el JWT que viaja en la cookie httpOnly (usa una cadena larga y aleatoria).
JWT_SECRET=cambia-este-valor-por-un-secreto-largo-y-aleatorio

# Secreto para firmar la cookie (@fastify/cookie). Puede ser distinto de JWT_SECRET.
COOKIE_SECRET=cambia-este-valor-tambien

PORT=3001

# Origen del cliente (Vite en dev, Netlify en producción) para configurar CORS.
CLIENT_ORIGIN=http://localhost:5173

NODE_ENV=development
